# KosKu Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:bfJCtE2D44NDW7X9@db.eiqupqysxndemshvmjzh.supabase.co:5432/postgres?sslmode=disable

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>

# ── Sentry (optional — leave empty to disable) ────────────────────────────────
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-resend-api-key>

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error  (default: info)
LOG_LEVEL=info
# LOG_PRETTY: true | false  (default: false — use true in local development)
LOG_PRETTY=false

# ── Gin ───────────────────────────────────────────────────────────────────────
# GIN_MODE: debug | release | test  (default: release)
GIN_MODE=release
